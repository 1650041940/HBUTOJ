# Runtime data generated by docker-compose (DB/Redis data, uploads, logs)
/standAlone/hbutoj/
/standAlone/hoj/
/standAlone/hoj
/standAlone/hbutoh
/distributed/**/hbutoj/
/distributed/**/hoj/

# Local environment files (keep *.example tracked)
/standAlone/.env
/standAlone/.env.local*
/distributed/main/.env
/distributed/judgeserver/.env
/distributed/**/.env.local*

# Local backups
/standAlone/.env.bak.*
/distributed/**/.env.bak.*

# Common
*.log

# Local build artifacts (too large for GitHub)
/src/backend/*.jar
/src/judgeserver/*.jar

# 由本文件生成本地配置：cp -n distributed/main/.env.example distributed/main/.env
# 注意：distributed/main/.env 不应提交到 git（包含密码/密钥）。

# HBUTOJ 全部数据存储的文件夹位置（默认当前路径生成 hbutoj 文件夹）
HBUTOJ_DATA_DIRECTORY=./hbutoj

# ===== 镜像发布/拉取配置（用于“改源码 -> 发镜像 -> 部署 pull 更新”） =====
# 默认指向上游镜像命名空间；如需使用你自己的镜像仓库，请替换为你的 GitHub 用户名或组织名。
HBUTOJ_IMAGE_PREFIX=ghcr.io/1650041940
HBUTOJ_MYSQL_IMAGE_PREFIX=ghcr.io/1650041940
HBUTOJ_MYSQL_CHECKER_IMAGE_PREFIX=ghcr.io/1650041940
HBUTOJ_IMAGE_TAG=latest
HBUTOJ_BACKEND_IMAGE_TAG=
HBUTOJ_FRONTEND_IMAGE_TAG=
HBUTOJ_MYSQL_IMAGE_TAG=
HBUTOJ_MYSQL_CHECKER_IMAGE_TAG=
HBUTOJ_MYSQL_IMAGE=hbutoj_database
HBUTOJ_BACKEND_IMAGE=hbutoj_backend
HBUTOJ_FRONTEND_IMAGE=hbutoj_frontend
HBUTOJ_JUDGESERVER_IMAGE=hbutoj_judgeserver
HBUTOJ_MYSQL_CHECKER_IMAGE=hbutoj_database_checker

# rsync 镜像（分布式数据同步）
HBUTOJ_RSYNC_IMAGE_PREFIX=ghcr.io/1650041940
HBUTOJ_RSYNC_IMAGE=hbutoj_rsync
HBUTOJ_RSYNC_IMAGE_TAG=latest

# redis的配置
REDIS_HOST=172.20.0.2
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME

# mysql的配置
MYSQL_HOST=172.20.0.3
MYSQL_PUBLIC_HOST=127.0.0.1
MYSQL_PUBLIC_PORT=3306
MYSQL_ROOT_PASSWORD=CHANGE_ME

# nacos的配置
NACOS_HOST=172.20.0.4
NACOS_PORT=8848
NACOS_USERNAME=root
NACOS_PASSWORD=CHANGE_ME

# backend后端服务的配置
BACKEND_HOST=172.20.0.5
BACKEND_PORT=6688

# frontend/mysql-checker 的固定 IP（如需修改 SUBNET，请同步修改这两个地址）
FRONTEND_HOST=172.20.0.6
MYSQL_CHECKER_HOST=172.20.0.7
JWT_TOKEN_SECRET=default
JWT_TOKEN_EXPIRE=86400
JWT_TOKEN_FRESH_EXPIRE=43200
JUDGE_TOKEN=default
EMAIL_SERVER_HOST=smtp.qq.com
EMAIL_SERVER_PORT=465
EMAIL_USERNAME=your_email_username
EMAIL_PASSWORD=your_email_password

HDU_ACCOUNT_USERNAME_LIST=
HDU_ACCOUNT_PASSWORD_LIST=
CF_ACCOUNT_USERNAME_LIST=
CF_ACCOUNT_PASSWORD_LIST=
POJ_ACCOUNT_USERNAME_LIST=
POJ_ACCOUNT_PASSWORD_LIST=
ATCODER_ACCOUNT_USERNAME_LIST=
ATCODER_ACCOUNT_PASSWORD_LIST=
SPOJ_ACCOUNT_USERNAME_LIST=
SPOJ_ACCOUNT_PASSWORD_LIST=
LIBRE_ACCOUNT_USERNAME_LIST=
LIBRE_ACCOUNT_PASSWORD_LIST=
FORCED_UPDATE_REMOTE_JUDGE_ACCOUNT=false

# 评测数据同步的配置
RSYNC_PASSWORD=CHANGE_ME

# docker network的配置
SUBNET=172.20.0.0/16

# ===== 内存与 JVM 限制（默认总和 < 3.9G） =====
REDIS_MEM_LIMIT=96M

MYSQL_MEM_LIMIT=512M
MYSQL_INNODB_BUFFER_POOL_SIZE=256M
MYSQL_MAX_CONNECTIONS=200

NACOS_MEM_LIMIT=320M
NACOS_JVM_XMX=256m
NACOS_JVM_XMS=256m
NACOS_JVM_XMN=128m

BACKEND_MEM_LIMIT=512M
BACKEND_JAVA_OPTS="-Xms128m -Xmx320m"

FRONTEND_MEM_LIMIT=96M

RSYNC_MEM_LIMIT=64M
MYSQL_CHECKER_MEM_LIMIT=128M
AUTOHEAL_MEM_LIMIT=32M

# 由本文件生成本地配置：cp -n distributed/judgeserver/.env.example distributed/judgeserver/.env
# 注意：distributed/judgeserver/.env 不应提交到 git（包含密码/密钥）。

# HBUTOJ 判题机数据存储目录（默认当前路径生成 judge 文件夹）
HBUTOJ_JUDGESERVER_DATA_DIRECTORY=./judge

# 兼容旧变量（后续会逐步废弃）：
# HOJ_JUDGESERVER_DATA_DIRECTORY=./judge

# ===== 镜像发布/拉取配置（用于“改源码 -> 发镜像 -> 部署 pull 更新”） =====
# 默认指向上游镜像命名空间；如需使用你自己的镜像仓库，请替换为你的 GitHub 用户名或组织名。
HBUTOJ_IMAGE_PREFIX=ghcr.io/1650041940
HBUTOJ_IMAGE_TAG=latest
HBUTOJ_JUDGESERVER_IMAGE=hbutoj_judgeserver

# rsync 镜像（分布式数据同步）
HBUTOJ_RSYNC_IMAGE_PREFIX=ghcr.io/1650041940
HBUTOJ_RSYNC_IMAGE=hbutoj_rsync
HBUTOJ_RSYNC_IMAGE_TAG=latest

# nacos的配置
NACOS_HOST=CHANGE_ME
NACOS_PORT=8848
NACOS_USERNAME=root
NACOS_PASSWORD=CHANGE_ME

# judgeserver的配置
JUDGE_SERVER_IP=127.0.0.1
JUDGE_SERVER_PORT=8088
JUDGE_SERVER_NAME=judger-1
MAX_TASK_NUM=-1
REMOTE_JUDGE_OPEN=true
REMOTE_JUDGE_MAX_TASK_NUM=-1
PARALLEL_TASK=default

# rsync评测数据同步的配置
RSYNC_MASTER_ADDR=127.0.0.1
RSYNC_PASSWORD=CHANGE_ME

# ===== 内存与 JVM 限制（默认总和 < 3.9G） =====
JUDGESERVER_MEM_LIMIT=512M
JUDGESERVER_JAVA_OPTS="-Xms128m -Xmx320m"

RSYNC_MEM_LIMIT=64M
